{
  "version": 2,
  "name": "bdms",
  "builds": [
    {
      "src": "index.php",
      "use": "@vercel/php"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/index.php"
    }
  ],
  "env": {
    "APP_ENV": "production"
  },
  "functions": {
    "api/*.php": {
      "runtime": "php8.1"
    }
  }
}
