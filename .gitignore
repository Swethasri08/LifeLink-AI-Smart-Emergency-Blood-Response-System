# BDMS .gitignore

# Environment files
.env
.env.local
.env.production

# Database files (keep SQL files, ignore backups)
*.sql.bak
*.sql.backup
db_backups/

# Logs
logs/
*.log
error.log
access.log

# Temporary files
temp/
tmp/
*.tmp
*.temp

# Cache
cache/
*.cache

# Session files
sessions/
*.sess

# Upload directories
uploads/
user_uploads/

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Composer
vendor/bin/
composer.lock

# Node.js (if using)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build outputs
dist/
build/

# Configuration files with sensitive data
config/database.local.php
config/local.php
config/production.php

# Backup and archive files
*.zip
*.tar.gz
*.rar
*.7z

# Test files
tests/
*.test.php
coverage/

# Documentation build
docs/_build/

# Local development
local/
dev/
staging/

# PHP specific
.php_cs.cache
.php_cs
.phpunit.result.cache

# Apache/Nginx specific
.htaccess.local
nginx.conf.local

# SSL certificates
*.crt
*.key
*.pem

# User uploaded content
uploads/
files/
documents/

# Generated reports
reports/
generated/
exports/

# Backup directories
backups/
old/

# Temporary session files
sessions/
cache/tmp/

# Error logs specific to BDMS
logs/error.log
logs/access.log
logs/debug.log

# Database dumps (except schema files)
db_dumps/
*.dump
